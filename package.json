{
  "name": "playwright-automation-framework",
  "version": "1.0.0",
  "description": "Production-ready Playwright automation framework with POM, API testing, and hybrid architecture",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "test:trace": "playwright show-trace"
  },
  "keywords": [
    "playwright",
    "automation",
    "testing",
    "typescript",
    "pom",
    "end-to-end"
  ],
  "author": "Darga Hajivali",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^latest",
    "typescript": "^latest"
  }
}